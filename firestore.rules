rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Catch-all Safety Net: Deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'oxentefesteje@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema Validation Helper for User Profiles
    function isValidUser(user) {
      return user.id is string && user.id.size() <= 128
          && user.name is string && user.name.size() <= 200
          && user.email is string && user.email.size() <= 200
          && user.status is string && (user.status == 'pending' || user.status == 'approved' || user.status == 'rejected');
    }

    // 2. Rules for the users collection
    match /users/{userId} {
      
      // Get: An authenticated user can get their own profile, or an Admin can get any profile
      allow get: if (
        isSignedIn() && 
        isValidId(userId) && 
        (isOwner(userId) || isAdmin())
      );

      // List: Only Admins can list all registered users (for approval dashboard)
      allow list: if (
        isSignedIn() && 
        isAdmin()
      );

      // Create: Users can register themselves
      // - Must sign their own record (UID matches document ID)
      // - Must pass schema validation
      // - Admins are auto-approved, others are always created as 'pending'
      // - Timestamps must match the request time (server-side timestamps validation)
      allow create: if (
        isSignedIn() && 
        isOwner(userId) && 
        isValidId(userId) && 
        isValidUser(incoming()) && (
          (isAdmin() && incoming().status == 'approved') ||
          (!isAdmin() && incoming().status == 'pending')
        ) && 
        incoming().createdAt == request.time && 
        incoming().updatedAt == request.time
      );

      // Update: Tiered identity logic
      // - Option A: Admin can update any field (e.g. status) as long as result is valid
      // - Option B: Owner can update their name/email but NOT their status, and id remains immutable
      allow update: if (
        isSignedIn() && 
        isValidId(userId) && 
        isValidUser(incoming()) && (
          (isAdmin() && incoming().updatedAt == request.time) ||
          (
            isOwner(userId) && 
            incoming().status == existing().status && 
            incoming().id == existing().id && 
            incoming().createdAt == existing().createdAt &&
            incoming().updatedAt == request.time &&
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'updatedAt'])
          )
        )
      );

      // Delete: Admins only
      allow delete: if (
        isSignedIn() && 
        isValidId(userId) && 
        isAdmin()
      );
    }
  }
}
